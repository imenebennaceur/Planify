# Backend
PORT=3000

# Simulator AI integration
# Required for file-based simulator analysis (/api/simulator/grade-from-report)
OPENAI_API_KEY=your_openai_api_key_here
AI_SIMULATOR_ENABLED=true
AI_SIMULATOR_MODEL=gpt-4.1-mini
AI_SIMULATOR_FILE_MODEL=gpt-4.1
AI_SIMULATOR_TIMEOUT_MS=9000
AI_REPORT_PROVIDER=local
# AI_REPORT_PROVIDER values:
# - auto   : try OpenAI, then Ollama, then local free fallback
# - openai : force OpenAI, then fallback local if unavailable
# - ollama : force Ollama, then fallback local if unavailable
# - local  : free deterministic local evaluator only

# Optional local free AI with Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Optional override (default is OpenAI Responses API)
# AI_SIMULATOR_API_URL=https://api.openai.com/v1/responses
